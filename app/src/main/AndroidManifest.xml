            android:exported="false" />
        <activity
            android:name=".activity.LiveOrderActivity"
            android:exported="false" />
        <activity
            android:name=".activity.user.OrderTrackingActivity"
            android:exported="false" />
        <activity
            android:name=".activity.OrderDetailActivity"
