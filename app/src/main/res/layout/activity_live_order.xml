<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    style="@style/MyBackground"
    android:fitsSystemWindows="true"
    tools:context=".activity.LiveOrderActivity">

    <ImageView
        android:id="@+id/backArrow"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/circle_background"
        android:elevation="4dp"
        android:padding="12dp"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Live Orders"
        android:textSize="20sp"
        android:textStyle="bold"
        style="@style/MyText"
        android:layout_marginStart="8dp"
        app:layout_constraintStart_toEndOf="@id/backArrow"
        app:layout_constraintTop_toTopOf="@id/backArrow"
        app:layout_constraintBottom_toBottomOf="@id/backArrow" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/ordersRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/backArrow"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_live_order" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/ordersRecyclerView"
        app:layout_constraintBottom_toBottomOf="@id/ordersRecyclerView"
        app:layout_constraintStart_toStartOf="@id/ordersRecyclerView"
        app:layout_constraintEnd_toEndOf="@id/ordersRecyclerView" />

    <TextView
        android:id="@+id/tvNoLiveOrders"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No active orders"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/ordersRecyclerView"
        app:layout_constraintBottom_toBottomOf="@id/ordersRecyclerView"
        app:layout_constraintStart_toStartOf="@id/ordersRecyclerView"
        app:layout_constraintEnd_toEndOf="@id/ordersRecyclerView" />

</androidx.constraintlayout.widget.ConstraintLayout>